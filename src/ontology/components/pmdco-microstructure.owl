# Class: pmdco:PMD_0020112 (Korngrößenverteilung)


# Class: pmdco:PMD_0020160 (ferrous metal microconstituent)

AnnotationAssertion(obo:IAO_0000114 pmdco:PMD_0020160 obo:IAO_0000122)
AnnotationAssertion(obo:IAO_0000117 pmdco:PMD_0020160 "PERSON: Philipp von Hartrott")
AnnotationAssertion(rdfs:comment pmdco:PMD_0020160 "Microconstiutents were coined in the times of light-optical metallography and are related to the differences that can be observed using this experimental process. 

In metallography the term phase is sometimes used to denote microconstituents. To avoid confusion, the term phase should only be used for thermodynamic phases."@en)
AnnotationAssertion(rdfs:label pmdco:PMD_0020160 "ferrous metal microconstituent"@en)
AnnotationAssertion(skos:definition pmdco:PMD_0020160 "A portion of matter that is at the same time an object at the microscopic scale which in turn is part of some ferrous metal."@en)
AnnotationAssertion(skos:example pmdco:PMD_0020160 "Pearlite is a microconstituent that has as parts some entities (lamellae) that at the same time are the thermodynamic phases ferrite (α-Fe) and cementite (Fe3C) . The characteristic spatial arrangement is in that case the lamellar orientation of the phases."@en)
AnnotationAssertion(pmdco:PMD_0000060 pmdco:PMD_0020160 "true"^^xsd:boolean)
SubClassOf(pmdco:PMD_0020160 ObjectIntersectionOf(pmdco:PMD_0000001 ObjectIntersectionOf(ObjectUnionOf(obo:BFO_0000027 obo:BFO_0000030) ObjectSomeValuesFrom(obo:BFO_0000050 pmdco:PMD_0000639))))
DisjointUnion(pmdco:PMD_0020160 pmdco:PMD_0020280 pmdco:PMD_0020281 pmdco:PMD_0020282 pmdco:PMD_0020283 pmdco:PMD_0020284 pmdco:PMD_0020285 pmdco:PMD_0020286)

# Class: pmdco:PMD_0020197 (lattice point)

AnnotationAssertion(rdfs:label pmdco:PMD_0020197 "lattice point"@en)
AnnotationAssertion(skos:definition pmdco:PMD_0020197 "A lattice point is a fiat point that represents a position in a crystal lattice at which structural entities are regularly arranged."@en)
SubClassOf(pmdco:PMD_0020197 obo:BFO_0000147)

# Class: pmdco:PMD_0020198 (interstitial site)

AnnotationAssertion(rdfs:label pmdco:PMD_0020198 "interstitial site"@en)
AnnotationAssertion(skos:definition pmdco:PMD_0020198 "An interstitial site is a site that is located between regular lattice points in a crystal structure."@en)
SubClassOf(pmdco:PMD_0020198 obo:BFO_0000029)

# Class: pmdco:PMD_0020199 (slip plane)

AnnotationAssertion(rdfs:label pmdco:PMD_0020199 "slip plane"@en)
AnnotationAssertion(skos:definition pmdco:PMD_0020199 "A slip plane is a fiat surface that corresponds to a crystallographic plane of a 3D crystal along which dislocations can glide"@en)
SubClassOf(pmdco:PMD_0020199 obo:BFO_0000146)

# Class: pmdco:PMD_0020206 (unit cell)

AnnotationAssertion(obo:IAO_0000119 pmdco:PMD_0020206 "https://www.physics-in-a-nutshell.com/article/5/unit-cell-primitive-cell-and-wigner-seitz-cell")
AnnotationAssertion(obo:IAO_0000233 pmdco:PMD_0020206 "https://github.com/materialdigital/core-ontology/pull/424")
AnnotationAssertion(rdfs:label pmdco:PMD_0020206 "unit cell"@en)
AnnotationAssertion(skos:definition pmdco:PMD_0020206 "Unit cell is a immaterial entity that represents the a smallest volume element a repetitive arrangement of which can build  up the whole crystal lattice without overplaps or gaps, and there is no further partition of the unit cell that could itself be used as a unit cell."@en)
SubClassOf(pmdco:PMD_0020206 obo:BFO_0000029)

# Class: pmdco:PMD_0020208 (slip direction)

AnnotationAssertion(rdfs:label pmdco:PMD_0020208 "slip direction"@en)
AnnotationAssertion(skos:definition pmdco:PMD_0020208 "A slip direction is a fiat line that corresponds to the crystallographic direction along which dislocations glide os a slip plane."@en)
SubClassOf(pmdco:PMD_0020208 obo:BFO_0000142)

# Class: pmdco:PMD_0020213 (grain boundary)

AnnotationAssertion(obo:IAO_0000116 pmdco:PMD_0020213 "the part of a grain that is close to the grain boundary and possibly characterized by disorder is a fiat object part (grain surface layer)"@en)
AnnotationAssertion(rdfs:label pmdco:PMD_0020213 "grain boundary"@en)
AnnotationAssertion(skos:definition pmdco:PMD_0020213 "A grain boundary is a fiat surface that separates adjacent grains in a polycrystalline material and is characterized by structural discontinuity."@en)
SubClassOf(pmdco:PMD_0020213 obo:BFO_0000146)
SubClassOf(pmdco:PMD_0020213 ObjectExactCardinality(2 obo:RO_0002350 ObjectIntersectionOf(pmdco:PMD_0020003 ObjectSomeValuesFrom(pmdco:PMD_0025998 pmdco:PMD_0020241))))

# Class: pmdco:PMD_0020224 (vacancy (crystal))

AnnotationAssertion(obo:IAO_0000116 pmdco:PMD_0020224 "TODO: replace topObjectProperty with occupies spatial region"@en)
AnnotationAssertion(rdfs:label pmdco:PMD_0020224 "vacancy (crystal)"@en)
AnnotationAssertion(skos:definition pmdco:PMD_0020224 "site at lattice point at which the crystal forming entity is missing"@en)
SubClassOf(pmdco:PMD_0020224 obo:BFO_0000147)
SubClassOf(pmdco:PMD_0020224 ObjectSomeValuesFrom(owl:topObjectProperty pmdco:PMD_0020197))

# Class: pmdco:PMD_0020233 (dislocation)

AnnotationAssertion(obo:IAO_0000114 pmdco:PMD_0020233 obo:IAO_0000122)
AnnotationAssertion(obo:IAO_0000117 pmdco:PMD_0020233 "PERSON: Philipp von Hartrott")
AnnotationAssertion(rdfs:label pmdco:PMD_0020233 "dislocation"@en)
AnnotationAssertion(skos:definition pmdco:PMD_0020233 "a linear site in a cystal that interrupts the cystal ordering"@en)
SubClassOf(pmdco:PMD_0020233 obo:BFO_0000142)

# Class: pmdco:PMD_0020234 (screw dislocation)

AnnotationAssertion(rdfs:label pmdco:PMD_0020234 "screw dislocation"@en)
AnnotationAssertion(skos:definition pmdco:PMD_0020234 "a dislocation characterized by shearing the chrystal by one plane"@en)
SubClassOf(pmdco:PMD_0020234 pmdco:PMD_0020233)

# Class: pmdco:PMD_0020235 (edge dislocation)

AnnotationAssertion(rdfs:label pmdco:PMD_0020235 "edge dislocation"@en)
AnnotationAssertion(skos:definition pmdco:PMD_0020235 "a dislocation characterized by adding one extra half plane into the crystal lattice"@en)
SubClassOf(pmdco:PMD_0020235 pmdco:PMD_0020233)

# Class: pmdco:PMD_0020236 (mixed dislocation)

AnnotationAssertion(rdfs:label pmdco:PMD_0020236 "mixed dislocation"@en)
AnnotationAssertion(skos:definition pmdco:PMD_0020236 "a dislocation that spans edge dislocation as well as screw dislocation"@en)
EquivalentClasses(pmdco:PMD_0020236 ObjectIntersectionOf(pmdco:PMD_0020234 pmdco:PMD_0020235))
SubClassOf(pmdco:PMD_0020236 pmdco:PMD_0020233)

# Class: pmdco:PMD_0020238 (high angle grain boundary)

AnnotationAssertion(rdfs:label pmdco:PMD_0020238 "high angle grain boundary"@en)
AnnotationAssertion(skos:definition pmdco:PMD_0020238 "a grain boundary whose adjacent crystalls have a high angle of misalignment"@en)
SubClassOf(pmdco:PMD_0020238 pmdco:PMD_0020213)

# Class: pmdco:PMD_0020239 (small angle grain boundary)

AnnotationAssertion(rdfs:label pmdco:PMD_0020239 "small angle grain boundary"@en)
AnnotationAssertion(skos:definition pmdco:PMD_0020239 "a grain boundary whose adjacent crystalls have a small angle of misalignment"@en)
SubClassOf(pmdco:PMD_0020239 pmdco:PMD_0020213)

# Class: pmdco:PMD_0020240 (twin boundary)

AnnotationAssertion(rdfs:label pmdco:PMD_0020240 "twin boundary"@en)
AnnotationAssertion(skos:definition pmdco:PMD_0020240 "grain boundary without distorted lattice"@en)
SubClassOf(pmdco:PMD_0020240 pmdco:PMD_0020213)

# Class: pmdco:PMD_0020280 (austenite)

AnnotationAssertion(obo:IAO_0000114 pmdco:PMD_0020280 obo:IAO_0000122)
AnnotationAssertion(obo:IAO_0000117 pmdco:PMD_0020280 "PERSON: Philipp von Hartrott")
AnnotationAssertion(rdfs:label pmdco:PMD_0020280 "austenite"@en)
AnnotationAssertion(skos:definition pmdco:PMD_0020280 "ferrous metal microconstituent which at the same time is a face-centered cubic iron crystall object or object aggregate"@en)
SubClassOf(pmdco:PMD_0020280 pmdco:PMD_0020000)
SubClassOf(pmdco:PMD_0020280 pmdco:PMD_0020160)

# Class: pmdco:PMD_0020281 (bainite)

AnnotationAssertion(obo:IAO_0000114 pmdco:PMD_0020281 obo:IAO_0000122)
AnnotationAssertion(obo:IAO_0000117 pmdco:PMD_0020281 "PERSON: Philipp von Hartrott")
AnnotationAssertion(rdfs:label pmdco:PMD_0020281 "bainite"@en)
AnnotationAssertion(skos:definition pmdco:PMD_0020281 "ferrous metal microconstituent which at the same time is a body centered cubic iron crystall object or object aggregate and has part some finely dispersed entities that at the same time are cementite thermodynamic phase"@en)
SubClassOf(pmdco:PMD_0020281 pmdco:PMD_0020160)
SubClassOf(pmdco:PMD_0020281 ObjectIntersectionOf(ObjectSomeValuesFrom(obo:BFO_0000051 pmdco:PMD_0020282) ObjectSomeValuesFrom(obo:BFO_0000051 pmdco:PMD_0027010)))

# Class: pmdco:PMD_0020282 (ferrite)

AnnotationAssertion(obo:IAO_0000114 pmdco:PMD_0020282 obo:IAO_0000122)
AnnotationAssertion(obo:IAO_0000117 pmdco:PMD_0020282 "PERSON: Philipp von Hartrott")
AnnotationAssertion(rdfs:label pmdco:PMD_0020282 "ferrite"@en)
AnnotationAssertion(skos:definition pmdco:PMD_0020282 "ferrous metal microconstituent which at the same time is a body centered cubic iron crystall object or object aggregate"@en)
SubClassOf(pmdco:PMD_0020282 pmdco:PMD_0020000)
SubClassOf(pmdco:PMD_0020282 pmdco:PMD_0020160)

# Class: pmdco:PMD_0020283 (ledeburite)

AnnotationAssertion(obo:IAO_0000114 pmdco:PMD_0020283 obo:IAO_0000122)
AnnotationAssertion(obo:IAO_0000117 pmdco:PMD_0020283 "PERSON: Philipp von Hartrott")
AnnotationAssertion(rdfs:label pmdco:PMD_0020283 "ledeburite"@en)
AnnotationAssertion(skos:definition pmdco:PMD_0020283 "ferrous metal microconstituent which at the same time is a face centered cubic iron crystall object or object aggregate and has part some entities that at the same time are cementite thermodynamic phase"@en)
SubClassOf(pmdco:PMD_0020283 pmdco:PMD_0020160)
SubClassOf(pmdco:PMD_0020283 ObjectIntersectionOf(ObjectSomeValuesFrom(obo:BFO_0000051 pmdco:PMD_0020280) ObjectSomeValuesFrom(obo:BFO_0000051 pmdco:PMD_0027010)))

# Class: pmdco:PMD_0020284 (martensite)

AnnotationAssertion(obo:IAO_0000114 pmdco:PMD_0020284 obo:IAO_0000122)
AnnotationAssertion(obo:IAO_0000117 pmdco:PMD_0020284 "PERSON: Philipp von Hartrott")
AnnotationAssertion(rdfs:label pmdco:PMD_0020284 "martensite"@en)
AnnotationAssertion(skos:definition pmdco:PMD_0020284 "ferrous metal microconstituent which at the same time is a tetragonal body centered iron crystall object or object aggregate"@en)
SubClassOf(pmdco:PMD_0020284 pmdco:PMD_0020160)

# Class: pmdco:PMD_0020285 (pearlite)

AnnotationAssertion(obo:IAO_0000114 pmdco:PMD_0020285 obo:IAO_0000122)
AnnotationAssertion(obo:IAO_0000117 pmdco:PMD_0020285 "PERSON: Philipp von Hartrott")
AnnotationAssertion(rdfs:label pmdco:PMD_0020285 "pearlite"@en)
AnnotationAssertion(skos:definition pmdco:PMD_0020285 "ferrous metal microconstituent which at the same time is a body centered cubic iron crystall object or object aggregate and has part some clearly lamella shaped entities that at the same time are cementite thermodynamic phase"@en)
SubClassOf(pmdco:PMD_0020285 pmdco:PMD_0020160)
SubClassOf(pmdco:PMD_0020285 ObjectIntersectionOf(ObjectSomeValuesFrom(obo:BFO_0000051 ObjectIntersectionOf(pmdco:PMD_0020282 pmdco:PMD_0027002)) ObjectSomeValuesFrom(obo:BFO_0000051 ObjectIntersectionOf(pmdco:PMD_0027002 pmdco:PMD_0027010))))

# Class: pmdco:PMD_0020286 (widmanstatten structure)

AnnotationAssertion(obo:IAO_0000114 pmdco:PMD_0020286 obo:IAO_0000122)
AnnotationAssertion(obo:IAO_0000117 pmdco:PMD_0020286 "PERSON: Philipp von Hartrott")
AnnotationAssertion(rdfs:label pmdco:PMD_0020286 "widmanstatten structure"@en)
AnnotationAssertion(skos:definition pmdco:PMD_0020286 "ferrous metal microconstituent which at the same time is a body centered cubic iron crystall object or object aggregate and has part some entities that at the same time are cementite thermodynamic phase"@en)
SubClassOf(pmdco:PMD_0020286 pmdco:PMD_0020160)

# Class: pmdco:PMD_0025001 (Zusammensetzung)


# Class: pmdco:PMD_0027001 (lamella)

AnnotationAssertion(obo:IAO_0000114 pmdco:PMD_0027001 obo:IAO_0000122)
AnnotationAssertion(obo:IAO_0000117 pmdco:PMD_0027001 "PERSON: PMDco Team")
AnnotationAssertion(rdfs:label pmdco:PMD_0027001 "lamella"@en)
AnnotationAssertion(skos:comment pmdco:PMD_0027001 "It may part of a lamellae object oggregate")
AnnotationAssertion(skos:definition pmdco:PMD_0027001 "lamella is an object that represents a thin, flat, plate-like layer or flake within microstructure."@en)
SubClassOf(pmdco:PMD_0027001 obo:BFO_0000030)
SubClassOf(pmdco:PMD_0027001 ObjectIntersectionOf(pmdco:PMD_0020000 pmdco:PMD_0020003))
DisjointClasses(pmdco:PMD_0027001 pmdco:PMD_0027004)

# Class: pmdco:PMD_0027002 (lamellae)

AnnotationAssertion(obo:IAO_0000112 pmdco:PMD_0027002 "perlite microconstituent has part ferrite lamellae and has part cementite lamellae. Ferrite lamellae has part ferrite lamella"@en)
AnnotationAssertion(obo:IAO_0000114 pmdco:PMD_0027002 obo:IAO_0000122)
AnnotationAssertion(obo:IAO_0000117 pmdco:PMD_0027002 "PERSON: PMDco Team")
AnnotationAssertion(rdfs:label pmdco:PMD_0027002 "lamellae"@en)
AnnotationAssertion(skos:definition pmdco:PMD_0027002 "lamellae is an object aggregate that is part of some microconstituent and at the same time a single thermodynamic phase"@en)
AnnotationAssertion(skos:example pmdco:PMD_0027002 "ferrite lamellae in perlite microcontituent"@en)
SubClassOf(pmdco:PMD_0027002 obo:BFO_0000027)
SubClassOf(pmdco:PMD_0027002 ObjectAllValuesFrom(obo:RO_0002351 pmdco:PMD_0027001))

# Class: pmdco:PMD_0027003 (average lamella thickness)

AnnotationAssertion(obo:IAO_0000114 pmdco:PMD_0027003 obo:IAO_0000122)
AnnotationAssertion(obo:IAO_0000117 pmdco:PMD_0027003 "PERSON: PMDco Team")
AnnotationAssertion(rdfs:label pmdco:PMD_0027003 "average lamella thickness"@en)
AnnotationAssertion(skos:definition pmdco:PMD_0027003 "average lamella thickness is a quality of lamellae object aggregate which defines the average thickness across all indivudual lamella(s) of a sinlge phase in a microconstituent"@en)
AnnotationAssertion(skos:example pmdco:PMD_0027003 "average thickness of ferrite lamellae in perlite microscontituent"@en)
SubClassOf(pmdco:PMD_0027003 obo:BFO_0000019)
SubClassOf(pmdco:PMD_0027003 ObjectIntersectionOf(ObjectSomeValuesFrom(obo:RO_0000080 pmdco:PMD_0027002) ObjectAllValuesFrom(obo:RO_0000080 pmdco:PMD_0027002)))

# Class: pmdco:PMD_0027004 (lath)

AnnotationAssertion(rdfs:label pmdco:PMD_0027004 "lath"@en)
AnnotationAssertion(skos:comment pmdco:PMD_0027004 "A lath is a crystal of a single phase. e.g., cementite in a crystallite of bainite microcontituent."@en)
AnnotationAssertion(skos:definition pmdco:PMD_0027004 "Lath is an elongated object and at the same time a crystal and a thermodynamic phase"@en)
AnnotationAssertion(skos:example pmdco:PMD_0027004 "lath of cementite embedded in ferrite matix in bainite microconstituent"@en)
SubClassOf(pmdco:PMD_0027004 obo:BFO_0000030)
SubClassOf(pmdco:PMD_0027004 ObjectIntersectionOf(pmdco:PMD_0020000 pmdco:PMD_0020003))

# Class: pmdco:PMD_0027005 (laths)

AnnotationAssertion(rdfs:label pmdco:PMD_0027005 "laths"@en)
AnnotationAssertion(skos:definition pmdco:PMD_0027005 "an object aggregate of multiple lath objects"@en)
SubClassOf(pmdco:PMD_0027005 obo:BFO_0000027)
SubClassOf(pmdco:PMD_0027005 ObjectAllValuesFrom(obo:RO_0002351 pmdco:PMD_0027004))

# Class: pmdco:PMD_0027006 (dislocation wall)

AnnotationAssertion(rdfs:label pmdco:PMD_0027006 "dislocation wall"@en)
AnnotationAssertion(skos:definition pmdco:PMD_0027006 "dislocation wall is a planar arrangement or localized boundary of dislocations inside a crystal lattice"@en)
SubClassOf(pmdco:PMD_0027006 obo:BFO_0000146)
SubClassOf(pmdco:PMD_0027006 ObjectSomeValuesFrom(obo:RO_0002351 pmdco:PMD_0020233))

# Class: pmdco:PMD_0027007 (dislocation cell)

AnnotationAssertion(rdfs:label pmdco:PMD_0027007 "dislocation cell"@en)
AnnotationAssertion(skos:definition pmdco:PMD_0027007 "dislocation cell is a microstructural feature in deformed crystal consisting of a nearly dislocation-free volume enclosed by tangled networks of dislocations forming cell walls"@en)
SubClassOf(pmdco:PMD_0027007 obo:BFO_0000029)
SubClassOf(pmdco:PMD_0027007 ObjectSomeValuesFrom(obo:RO_0002351 pmdco:PMD_0020233))
SubClassOf(pmdco:PMD_0027007 ObjectSomeValuesFrom(obo:RO_0002351 pmdco:PMD_0027006))

# Class: pmdco:PMD_0027008 (stacking fault)

AnnotationAssertion(rdfs:label pmdco:PMD_0027008 "stacking fault"@en)
AnnotationAssertion(skos:definition pmdco:PMD_0027008 "stacking fault is a planar defect in  hcp or fcc crystal characterized by a local error in the layering sequence of atomic planes"@en)
SubClassOf(pmdco:PMD_0027008 obo:BFO_0000146)

# Class: pmdco:PMD_0027009 (Cottrell cloud)

AnnotationAssertion(rdfs:label pmdco:PMD_0027009 "Cottrell cloud"@en)
AnnotationAssertion(skos:altLabel pmdco:PMD_0027009 "Cottrell atmosphere")
AnnotationAssertion(skos:definition pmdco:PMD_0027009 "Cottrell cloud is a site which contains a dislocation and at least one interstitial atom at its core. The formation of the Cottrell cloud is guided by the reduction of residual stress due to lattice distortion around a interstitial atom, as dislocation has greater vacancy at its core."@en)
SubClassOf(pmdco:PMD_0027009 obo:BFO_0000029)

# Class: pmdco:PMD_0027010 (cementite)

AnnotationAssertion(rdfs:label pmdco:PMD_0027010 "cementite"@en)
AnnotationAssertion(skos:definition pmdco:PMD_0027010 "ferrous metal microconstituent which at the same time an intermetallic phase of Fe3C with orthorhombic crystal lattice")
SubClassOf(pmdco:PMD_0027010 pmdco:PMD_0020000)
SubClassOf(pmdco:PMD_0027010 pmdco:PMD_0020160)

# Class: pmdco:PMD_0027011 (upper bainite)

AnnotationAssertion(rdfs:label pmdco:PMD_0027011 "upper bainite"@en)
SubClassOf(pmdco:PMD_0027011 pmdco:PMD_0020281)

# Class: pmdco:PMD_0027012 (lower bainite)

AnnotationAssertion(rdfs:label pmdco:PMD_0027012 "lower bainite"@en)
SubClassOf(pmdco:PMD_0027012 pmdco:PMD_0020281)

# Class: pmdco:PMD_0080597 (vector density fields)



DisjointClasses(pmdco:PMD_0000503 pmdco:PMD_0000512 pmdco:PMD_0000591 pmdco:PMD_0000595 pmdco:PMD_0000853 pmdco:PMD_0000896 pmdco:PMD_0000942 pmdco:PMD_0000967 pmdco:PMD_0020112 pmdco:PMD_0020160 pmdco:PMD_0025001 pmdco:PMD_0080597)
DisjointClasses(pmdco:PMD_0020280 pmdco:PMD_0020281 pmdco:PMD_0020282 pmdco:PMD_0020283 pmdco:PMD_0020284 pmdco:PMD_0020285 pmdco:PMD_0020286)
